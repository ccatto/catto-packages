{
  "name": "@catto/react-auth",
  "version": "1.0.0",
  "description": "Catto Auth - React/Next.js authentication with Better Auth, JWT, and mobile support",
  "license": "MIT",
  "author": "Chris Catto",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "better-auth": "^1.2.8",
    "glob": "^13.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "better-auth": ">=1.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0 || >=19.0.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@apollo/client": {
      "optional": true
    },
    "@capacitor/core": {
      "optional": true
    },
    "@capacitor/preferences": {
      "optional": true
    },
    "@simplewebauthn/browser": {
      "optional": true
    },
    "graphql": {
      "optional": true
    }
  }
}
