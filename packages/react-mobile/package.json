{
  "name": "@ccatto/react-mobile",
  "version": "1.0.0",
  "description": "Catto Mobile - React hooks for Capacitor mobile apps",
  "license": "MIT",
  "author": "Chris Catto",
  "keywords": [
    "react",
    "capacitor",
    "mobile",
    "hooks",
    "typescript",
    "catto"
  ],
  "homepage": "https://github.com/ccatto/catto-packages/tree/main/packages/react-mobile",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccatto/catto-packages.git",
    "directory": "packages/react-mobile"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ccatto/logger": "^1.0.0"
  },
  "devDependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "glob": "^13.0.0",
    "jsdom": "^27.4.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@capacitor/app": ">=5.0.0",
    "@capacitor/core": ">=5.0.0",
    "@capacitor/haptics": ">=5.0.0",
    "@capacitor/keyboard": ">=5.0.0",
    "@capacitor/network": ">=5.0.0",
    "@capacitor/share": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/app": {
      "optional": true
    },
    "@capacitor/haptics": {
      "optional": true
    },
    "@capacitor/keyboard": {
      "optional": true
    },
    "@capacitor/network": {
      "optional": true
    },
    "@capacitor/share": {
      "optional": true
    }
  }
}
