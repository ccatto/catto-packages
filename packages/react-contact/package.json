{
  "name": "@catto/react-contact",
  "version": "1.0.0",
  "description": "Catto Contact - React hooks and schema factory for contact forms",
  "license": "MIT",
  "author": "Chris Catto",
  "keywords": [
    "react",
    "contact-form",
    "hooks",
    "zod",
    "typescript",
    "catto"
  ],
  "homepage": "https://github.com/ccatto/catto-packages/tree/main/packages/react-contact",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccatto/catto-packages.git",
    "directory": "packages/react-contact"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@catto/logger": "^1.0.0"
  },
  "devDependencies": {
    "@hookform/resolvers": "^4.0.0",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "glob": "^13.0.0",
    "jsdom": "^27.4.0",
    "react": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.16",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=3.0.0",
    "@catto/profanity": ">=1.0.0",
    "react": ">=18.0.0",
    "react-hook-form": ">=7.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@catto/profanity": {
      "optional": true
    }
  }
}
